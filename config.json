{
  "$schema": "./config-schema.json",
  "version": "1.0.0",
  "name": "my-awesome-model-router",
  "description": "Custom skills plugin with role-based model selection",
  
  "modelProviders": {
    "k2.5": "volcengine-plan/kimi-k2.5",
    "glm5": "volcengine-plan/glm-5",
    "deepseekv3.2": "baiduqianfancodingplan/deepseek-v3.2",
    "m2.7": "minimax-cn-coding-plan/MiniMax-M2.7"
  },
  
  "agents": {
    "frontend": {
      "model": "k2.5",
      "skills": ["frontend-developer"],
      "description": "Frontend development specialist"
    },
    "architect": {
      "model": "k2.5",
      "skills": ["architect"],
      "description": "System architecture and design specialist"
    },
    "backend": {
      "model": "glm5",
      "skills": ["backend-developer"],
      "description": "Backend development specialist"
    },
    "tester": {
      "model": "deepseekv3.2",
      "skills": ["tester"],
      "description": "Testing and quality assurance specialist"
    },
    "qa": {
      "model": "deepseekv3.2",
      "skills": ["qa-engineer"],
      "description": "Quality assurance and process improvement specialist"
    },
    "debugger": {
      "model": "deepseekv3.2",
      "skills": ["debugger"],
      "description": "Debugging and root cause analysis specialist"
    },
    "documenter": {
      "model": "m2.7",
      "skills": ["documenter"],
      "description": "Technical documentation specialist"
    },
    "refactoring-specialist": {
      "model": "k2.5",
      "skills": ["refactoring-specialist"],
      "description": "Code refactoring and technical debt reduction specialist"
    },
    "database-specialist": {
      "model": "glm5",
      "skills": ["database-specialist"],
      "description": "Database design and optimization specialist"
    }
  },
  
  "categories": {
    "frontend-architecture": {
      "model": "k2.5",
      "description": "Frontend and architecture tasks",
      "agents": ["frontend", "architect", "refactoring-specialist"]
    },
    "requirement-implementation": {
      "model": "glm5",
      "description": "Feature implementation and requirement fulfillment",
      "agents": ["backend", "frontend", "database-specialist"]
    },
    "bug-fix": {
      "model": "deepseekv3.2",
      "description": "Bug investigation and fixing",
      "agents": ["tester", "qa", "backend", "debugger"]
    },
    "debugging": {
      "model": "deepseekv3.2",
      "description": "Debugging and root cause analysis",
      "agents": ["debugger", "tester"]
    },
    "documentation": {
      "model": "m2.7",
      "description": "Technical documentation tasks",
      "agents": ["documenter"]
    },
    "refactoring": {
      "model": "k2.5",
      "description": "Code refactoring and improvement",
      "agents": ["refactoring-specialist", "architect"]
    },
    "database": {
      "model": "glm5",
      "description": "Database design and optimization",
      "agents": ["database-specialist", "backend"]
    },
    "low-difficulty": {
      "model": "m2.7",
      "description": "Simple, repetitive tasks",
      "agents": ["frontend", "backend", "tester", "documenter"]
    },
    "fallback": {
      "model": "m2.7",
      "description": "Default fallback for unspecified tasks",
      "agents": ["frontend", "backend", "tester", "qa"]
    }
  },
  


  "fallbackChains": {
    "frontend": ["k2.5", "glm5", "m2.7"],
    "architect": ["k2.5", "glm5", "m2.7"],
    "backend": ["glm5", "k2.5", "m2.7"],
    "tester": ["deepseekv3.2", "glm5", "m2.7"],
    "qa": ["deepseekv3.2", "glm5", "m2.7"],
    "debugger": ["deepseekv3.2", "glm5", "m2.7"],
    "documenter": ["m2.7", "glm5"],
    "refactoring-specialist": ["k2.5", "glm5", "m2.7"],
    "database-specialist": ["glm5", "deepseekv3.2", "m2.7"],
    "default": ["m2.7"]
  },

  "categoryKeywords": {
    "frontend-architecture": ["frontend", "ui", "component", "interface"],
    "requirement-implementation": ["implement", "feature", "requirement", "backend"],
    "bug-fix": ["bug", "fix", "error", "issue"],
    "debugging": ["debug", "investigate", "root cause"],
    "documentation": ["document", "readme", "comment"],
    "refactoring": ["refactor", "cleanup", "restructure"],
    "database": ["database", "query", "sql", "schema"],
    "low-difficulty": ["simple", "routine", "easy"]
  }
}
